# ============================================================================
# VanityPOS - Environment Configuration Template
# ============================================================================
# Copy this file to .env for local development
# For production, set these variables in your hosting platform (e.g., Vercel)
# ============================================================================

# ----------------------------------------------------------------------------
# Application Environment
# ----------------------------------------------------------------------------
NODE_ENV=development
# Options: development, production, test

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# Development (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL) - Replace with your actual database URL
# DATABASE_URL="postgresql://username:password@host:port/database?schema=public&sslmode=require"

# Database Connection Pool Settings (Production)
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000

# ----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# ----------------------------------------------------------------------------
# IMPORTANT: Generate a secure secret for production
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"

# Application URL
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://your-domain.com"

# Session Configuration
SESSION_MAX_AGE=2592000
# 30 days in seconds (30 * 24 * 60 * 60)

# ----------------------------------------------------------------------------
# Redis Cache (Optional but recommended for production)
# ----------------------------------------------------------------------------
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD="your-redis-password"
# REDIS_TLS_ENABLED=false

# Production Redis (with TLS)
# REDIS_URL="rediss://username:password@host:port"
# REDIS_TLS_ENABLED=true

# ----------------------------------------------------------------------------
# Email Configuration (Optional)
# ----------------------------------------------------------------------------
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="your-email@gmail.com"
# EMAIL_SERVER_PASSWORD="your-app-password"
# EMAIL_FROM="noreply@vanityhub.com"

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
# 100 requests per minute

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=false

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# File Storage (Optional)
# ----------------------------------------------------------------------------
# Vercel Blob Storage
# BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# AWS S3 (Alternative)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="your-bucket-name"

# ----------------------------------------------------------------------------
# Payment Gateway (Optional)
# ----------------------------------------------------------------------------
# Stripe
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal
# PAYPAL_CLIENT_ID="your-client-id"
# PAYPAL_CLIENT_SECRET="your-client-secret"
# PAYPAL_MODE="sandbox"
# Options: sandbox, live

# ----------------------------------------------------------------------------
# Monitoring & Analytics (Optional)
# ----------------------------------------------------------------------------
# Sentry Error Tracking
# SENTRY_DSN="https://...@sentry.io/..."
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Inventory Management
ALLOW_NEGATIVE_STOCK=false
ENABLE_BATCH_TRACKING=true
ENABLE_STOCK_ALERTS=true

# Client Portal
ENABLE_ONLINE_BOOKING=true
ENABLE_CLIENT_PORTAL=true

# Loyalty & Rewards
ENABLE_LOYALTY_PROGRAM=true
ENABLE_GIFT_CARDS=true
ENABLE_MEMBERSHIPS=true

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR, CRITICAL

# Enable detailed logging in development
# LOG_LEVEL=DEBUG

# ----------------------------------------------------------------------------
# Performance & Optimization
# ----------------------------------------------------------------------------
# Cache TTL (Time To Live) in seconds
CACHE_TTL_DEFAULT=300
# 5 minutes

CACHE_TTL_STATIC=3600
# 1 hour for static data

CACHE_TTL_DYNAMIC=60
# 1 minute for dynamic data

# ----------------------------------------------------------------------------
# Build Configuration
# ----------------------------------------------------------------------------
# NPM Configuration
NPM_CONFIG_LEGACY_PEER_DEPS=true

# Node.js Memory Limit (for builds)
NODE_OPTIONS=--max-old-space-size=4096

# ----------------------------------------------------------------------------
# CORS Configuration (if needed for API)
# ----------------------------------------------------------------------------
# ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# ----------------------------------------------------------------------------
# Timezone & Localization
# ----------------------------------------------------------------------------
TZ=Asia/Qatar
DEFAULT_CURRENCY=QAR
DEFAULT_LOCALE=en-US

# ----------------------------------------------------------------------------
# Development Tools
# ----------------------------------------------------------------------------
# Enable development features
ENABLE_DEV_TOOLS=true
# Set to false in production

# Prisma Studio
# PRISMA_STUDIO_PORT=5555

# ----------------------------------------------------------------------------
# API Keys (Third-party services)
# ----------------------------------------------------------------------------
# SMS Service (e.g., Twilio)
# TWILIO_ACCOUNT_SID="your-account-sid"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# WhatsApp Business API
# WHATSAPP_API_KEY="your-api-key"
# WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# ----------------------------------------------------------------------------
# Backup Configuration
# ----------------------------------------------------------------------------
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"
# Daily at 2 AM

# BACKUP_RETENTION_DAYS=30
# Keep backups for 30 days

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Never commit .env files to version control
# 2. Use strong, unique secrets for production
# 3. Rotate secrets regularly
# 4. Use environment-specific values
# 5. Enable SSL/TLS for all production services
# 6. Use managed services for databases and caching in production
# 7. Set up proper monitoring and alerting
# ============================================================================


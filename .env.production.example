# ============================================================================
# VanityPOS - Production Environment Configuration Template
# ============================================================================
# This file contains production-specific environment variables
# Set these in your hosting platform (Vercel, AWS, etc.)
# ============================================================================

# ----------------------------------------------------------------------------
# Application Environment
# ----------------------------------------------------------------------------
NODE_ENV=production

# ----------------------------------------------------------------------------
# Database Configuration (PostgreSQL Required for Production)
# ----------------------------------------------------------------------------
# IMPORTANT: Use a managed PostgreSQL service (e.g., Neon, Supabase, AWS RDS)
DATABASE_URL="postgresql://username:password@host:port/database?schema=public&sslmode=require"

# Connection Pool Settings
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_POOL_IDLE_TIMEOUT=30000

# ----------------------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------------------
# CRITICAL: Generate a strong secret for production
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET_MINIMUM_32_CHARACTERS"

# Production URL
NEXTAUTH_URL="https://your-production-domain.com"

# Session Configuration
SESSION_MAX_AGE=2592000

# ----------------------------------------------------------------------------
# Redis Cache (REQUIRED for Production)
# ----------------------------------------------------------------------------
# Use managed Redis service (e.g., Upstash, Redis Cloud, AWS ElastiCache)
REDIS_URL="rediss://username:password@host:port"
REDIS_TLS_ENABLED=true

# ----------------------------------------------------------------------------
# Email Configuration (REQUIRED for Production)
# ----------------------------------------------------------------------------
EMAIL_SERVER_HOST="smtp.sendgrid.net"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="your-sendgrid-api-key"
EMAIL_FROM="noreply@your-domain.com"

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Rate Limiting (REQUIRED)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Password Policy (Enforced)
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# Audit Logging (REQUIRED)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# File Storage (REQUIRED for Production)
# ----------------------------------------------------------------------------
# Vercel Blob Storage (Recommended for Vercel deployments)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# ----------------------------------------------------------------------------
# Payment Gateway (Configure if using payments)
# ----------------------------------------------------------------------------
# Stripe (Production Keys)
STRIPE_PUBLIC_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----------------------------------------------------------------------------
# Monitoring & Error Tracking (REQUIRED)
# ----------------------------------------------------------------------------
# Sentry for Error Tracking
SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"
SENTRY_ENVIRONMENT=production

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ALLOW_NEGATIVE_STOCK=false
ENABLE_BATCH_TRACKING=true
ENABLE_STOCK_ALERTS=true
ENABLE_ONLINE_BOOKING=true
ENABLE_CLIENT_PORTAL=true
ENABLE_LOYALTY_PROGRAM=true
ENABLE_GIFT_CARDS=true
ENABLE_MEMBERSHIPS=true

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Performance & Optimization
# ----------------------------------------------------------------------------
CACHE_TTL_DEFAULT=600
CACHE_TTL_STATIC=3600
CACHE_TTL_DYNAMIC=60

# ----------------------------------------------------------------------------
# Build Configuration (Vercel)
# ----------------------------------------------------------------------------
NPM_CONFIG_LEGACY_PEER_DEPS=true
NODE_OPTIONS=--max-old-space-size=4096

# ----------------------------------------------------------------------------
# Timezone & Localization
# ----------------------------------------------------------------------------
TZ=Asia/Qatar
DEFAULT_CURRENCY=QAR
DEFAULT_LOCALE=en-US

# ----------------------------------------------------------------------------
# SMS Service (Optional)
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ----------------------------------------------------------------------------
# Backup Configuration
# ----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# ----------------------------------------------------------------------------
# IMPORTANT PRODUCTION CHECKLIST
# ----------------------------------------------------------------------------
# [ ] Replace all placeholder values with actual production credentials
# [ ] Use strong, unique secrets (minimum 32 characters)
# [ ] Enable SSL/TLS for all services
# [ ] Use managed database service with automatic backups
# [ ] Set up Redis for caching and session management
# [ ] Configure error tracking (Sentry)
# [ ] Set up monitoring and alerting
# [ ] Enable rate limiting
# [ ] Configure email service for notifications
# [ ] Set up file storage (Vercel Blob or S3)
# [ ] Test all integrations in staging environment first
# [ ] Set up automated backups
# [ ] Configure CORS if needed
# [ ] Enable security headers
# [ ] Set up SSL certificates
# [ ] Configure CDN for static assets
# ============================================================================

